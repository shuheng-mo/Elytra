# =============================================================================
# LLM Provider — pick ONE of the two strategies below
# =============================================================================

# Strategy A (recommended): single OpenRouter key, every model goes through it.
# Get a key at https://openrouter.ai. Models must be in vendor/model form.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # default; override if proxying

# Strategy B (legacy): per-vendor keys. Only used if OPENROUTER_API_KEY is empty.
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-xxx

# =============================================================================
# Database
# =============================================================================
# DATABASE_URL is the *infrastructure DB* used by Elytra itself for
# `query_history` and `schema_embeddings` (pgvector). It is NOT what the agent
# queries on behalf of users — analytics queries flow through the connector
# registry below.
#
# IMPORTANT: the host depends on how you run the backend:
#   - Docker Compose (方式 1): host is `db` — the compose service name resolves
#     inside the docker network only.
#   - Local dev (方式 2, backend on the host): host is `localhost` — the
#     `db` name does not exist outside the compose network.
# The line below is the docker-compose default. If you're running uvicorn on
# your host machine, change `db` to `localhost`.
DATABASE_URL=postgresql://Elytra:Elytra_dev@db:5432/Elytra

# =============================================================================
# Data sources (multi-source connector registry)
# =============================================================================
# Elytra v0.2.0+ uses `config/datasources.yaml` as the single source of truth
# for analytics data sources. The YAML supports `${VAR:-default}` placeholders;
# the variables below are referenced by the default ecommerce_pg / starrocks
# entries. Override them in this .env to point at your own infrastructure.
#
# `DEFAULT_SOURCE` overrides the YAML's `default_source` field. Leave it
# empty to use whatever the YAML declares.
# DEFAULT_SOURCE=ecommerce_pg

# ----- ecommerce_pg connection block -----------------------------------------
# Same docker-vs-local rule as DATABASE_URL above: use `db` inside compose,
# `localhost` when running the backend on the host.
DB_HOST=db
DB_PORT=5432
DB_NAME=Elytra
DB_USER=Elytra
DB_PASSWORD=Elytra_dev

# ----- ecommerce_starrocks (optional, only when StarRocks compose is up) -----
# STARROCKS_HOST=localhost
# STARROCKS_PORT=9030
# STARROCKS_DB=elytra
# STARROCKS_USER=root
# STARROCKS_PASSWORD=

# =============================================================================
# Models
# =============================================================================
# When using OpenRouter, names must be vendor-prefixed. Bare names like
# "deepseek-chat" are auto-mapped via src/agent/llm._OPENROUTER_MODEL_ALIASES,
# but it's clearer to write them out.
DEFAULT_CHEAP_MODEL=deepseek/deepseek-chat
DEFAULT_STRONG_MODEL=anthropic/claude-sonnet-4

# =============================================================================
# Embedding — three backends, auto-selected from EMBEDDING_MODEL prefix
# =============================================================================
# IMPORTANT — OpenRouter does NOT proxy the /v1/embeddings endpoint. It only
# routes chat completions. So even though chat models above use OpenRouter,
# embeddings have to come from one of:
#   A) Local sentence-transformers (recommended — no API key, no network)
#   B) OpenAI direct (requires a real OPENAI_API_KEY, not just OpenRouter)
#
# Also: pgvector's HNSW index has a hard 2000-dim ceiling. text-embedding-3-large
# (3072 dim) will NOT work as-is — pick a model with ≤ 2000 dim.
#
# A) Local sentence-transformers (DEFAULT — no key, ~100MB one-time download):
#    Install the extra first:  uv sync --extra local-embed
#    Recommended Chinese model: BAAI/bge-small-zh-v1.5 (512 dim).
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
#
# B) OpenAI direct (set OPENAI_API_KEY above and use a bare model name):
# EMBEDDING_MODEL=text-embedding-3-small
#
# Force a specific provider instead of auto-detection:
# EMBEDDING_PROVIDER=auto    # auto | openai | openrouter | local
#
# Override the auto-detected vector dim (only needed for non-standard models):
# EMBEDDING_DIM=1536
#
# NOTE: switching embedding model changes the vector dim, which means the
# schema_embeddings table must be rebuilt. Run:
#     python -m src.retrieval.bootstrap                # full re-index
#     python -m src.retrieval.bootstrap --source <name>  # single source
# The bootstrap iterates every entry in config/datasources.yaml, applies the
# overlay, and writes one row per non-SYSTEM table tagged with source_name.

# =============================================================================
# Retrieval
# =============================================================================
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6
RERANK_TOP_K=5
MAX_RETRY_COUNT=3
SQL_TIMEOUT_SECONDS=30
